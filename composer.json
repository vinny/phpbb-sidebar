{
	"name": "vinny/sidebar",
	"type": "phpbb-extension",
	"description": "Sidebar Manager for phpBB. Adds customizable sidebars to the forum.",
	"homepage": "https://github.com/vinny/phpbb-sidebar",
	"version": "1.0.1",
	"time": "2026-05-12",
	"keywords": ["phpbb", "extension", "add-on", "sidebar"],
	"license": "GPL-2.0-only",
	"authors": [
		{
			"name": "Vinny",
			"role": "Developer"
		}
	],
	"require": {
		"php": ">=7.2.0",
		"phpbb/phpbb": ">=3.3.0"
	},
	"extra": {
		"display-name": "Sidebar Manager",
		"soft-require": {
			"phpbb/phpbb": "^3.3.0"
		},
        "version-check": {
            "host": "www.phpbb.com",
            "directory": "/customise/db/extension/sidebar",
            "filename": "version_check",
            "ssl": true
        }
	}
}